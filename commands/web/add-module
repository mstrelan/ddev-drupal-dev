#!/usr/bin/env bash

#ddev-generated
## Description: Clone a contrib module for development
## Usage: add-module [--https] <module_name> [branch]
## Example: "ddev add-module token" or "ddev add-module token 2.0.x"
## ExecRaw: true
## MutagenSync: true

set -e

USE_HTTPS=false

# Parse flags.
while [[ "$1" == --* ]]; do
  case "$1" in
    --https) USE_HTTPS=true; shift ;;
    *) echo "Unknown option: $1. Run 'ddev add-module' for usage."; exit 1 ;;
  esac
done

if [ $# -eq 0 ]; then
  echo "Usage: ddev add-module [--https] <module_name> [branch]"
  echo ""
  echo "Clones a Drupal contrib module, registers it as a path repository"
  echo "in composer.local.json, and runs composer require."
  echo ""
  echo "Options:"
  echo "  --https    Clone via HTTPS instead of SSH (read-only, no push access)"
  echo ""
  echo "SSH cloning requires 'ddev auth ssh' to forward your SSH keys."
  echo ""
  echo "Examples:"
  echo "  ddev add-module token          # auto-detects the latest branch"
  echo "  ddev add-module token 2.0.x    # uses a specific branch"
  echo "  ddev add-module --https token  # clone via HTTPS"
  exit 1
fi

MODULE_NAME="$1"
BRANCH="$2"

if [[ ! "$MODULE_NAME" =~ ^[a-z][a-z0-9_]*$ ]]; then
  echo "Error: Invalid module name '$MODULE_NAME'."
  echo "Must start with a lowercase letter, contain only lowercase letters, numbers, and underscores."
  exit 1
fi

# Read the install path for drupal-module from Composer's installer-paths config.
MODULE_DIR=$(composer config extra.installer-paths --json 2>/dev/null \
  | jq -r 'to_entries[] | select(.value[] == "type:drupal-module") | .key' 2>/dev/null \
  | sed "s/{\\\$name}/$MODULE_NAME/")
if [ -z "$MODULE_DIR" ]; then
  MODULE_DIR="modules/contrib/$MODULE_NAME"
fi
DRUPAL_GIT_HTTPS="https://git.drupalcode.org/project/$MODULE_NAME.git"
DRUPAL_GIT_SSH="git@git.drupalcode.org:project/$MODULE_NAME.git"

if [ -d "$MODULE_DIR" ]; then
  if [ ! -d "$MODULE_DIR/.git" ]; then
    echo "Error: $MODULE_DIR already exists but is not a git checkout."
    echo "Remove it first with: ddev remove-module $MODULE_NAME"
    exit 1
  fi
  printf '%s already exists as a git checkout. Register it with Composer? [y/N] ' "$MODULE_DIR"
  read -r REPLY
  if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
    exit 0
  fi
  BRANCH=$(git -C "$MODULE_DIR" symbolic-ref --short HEAD 2>/dev/null)
  if [ -z "$BRANCH" ]; then
    echo "Error: Could not determine the current branch of $MODULE_DIR (detached HEAD?)."
    exit 1
  fi
  echo "Using existing checkout on branch: $BRANCH"
else
  # Build the remote URL.
  if [ "$USE_HTTPS" = true ]; then
    REMOTE_URL="$DRUPAL_GIT_HTTPS"
  else
    REMOTE_URL="$DRUPAL_GIT_SSH"
  fi

  # Auto-detect branch if not specified (always use HTTPS for ls-remote).
  if [ -z "$BRANCH" ]; then
    echo "Detecting default branch for $MODULE_NAME..."
    BRANCH=$(git ls-remote --symref "$DRUPAL_GIT_HTTPS" HEAD 2>/dev/null \
      | grep '^ref: ' | sed 's/^ref: refs\/heads\///' | sed 's/\tHEAD$//')
    if [ -z "$BRANCH" ]; then
      echo "Error: Could not detect default branch. Specify one manually:"
      echo "  ddev add-module $MODULE_NAME <branch>"
      exit 1
    fi
    echo "Using branch: $BRANCH"
  fi

  # Clone the module.
  echo "Cloning drupal/$MODULE_NAME ($BRANCH) into $MODULE_DIR..."
  if ! git clone --branch "$BRANCH" "$REMOTE_URL" "$MODULE_DIR"; then
    echo "Error: Failed to clone drupal/$MODULE_NAME. Check that the module and branch exist."
    exit 1
  fi
fi

# Find the dev version from the canonical Drupal Composer repo that matches
# our branch, so the lock file records the correct dev version.
DEV_VERSIONS=$(composer show --all "drupal/$MODULE_NAME" --format=json 2>/dev/null \
  | jq -r '.versions[]' 2>/dev/null | grep -E '\-dev$|^dev-' || true)
COMPOSER_VERSION=""
# Try direct match: 2.0.x → 2.0.x-dev
if echo "$DEV_VERSIONS" | grep -qx "${BRANCH}-dev"; then
  COMPOSER_VERSION="${BRANCH}-dev"
# Try dev- prefix: main → dev-main
elif echo "$DEV_VERSIONS" | grep -qx "dev-${BRANCH}"; then
  COMPOSER_VERSION="dev-${BRANCH}"
# Try legacy Drupal format: 8.x-1.x → strip prefix → 1.x-dev
elif [[ "$BRANCH" =~ ^[0-9]+\.x-(.+)$ ]]; then
  STRIPPED="${BASH_REMATCH[1]}"
  if echo "$DEV_VERSIONS" | grep -qx "${STRIPPED}-dev"; then
    COMPOSER_VERSION="${STRIPPED}-dev"
  elif echo "$DEV_VERSIONS" | grep -qx "dev-${STRIPPED}"; then
    COMPOSER_VERSION="dev-${STRIPPED}"
  fi
fi
if [ -z "$COMPOSER_VERSION" ]; then
  COMPOSER_VERSION="*"
fi

# Register as a path repository and require it. The composer-git-installer
# plugin detects the .git directory and skips the download, preserving
# the checkout.
echo "Adding path repository and requiring drupal/$MODULE_NAME..."
composer config repositories.$MODULE_NAME path "$MODULE_DIR"
composer require --no-interaction --update-with-all-dependencies "drupal/$MODULE_NAME:$COMPOSER_VERSION"

# Remove the #ddev-generated marker from composer files since
# they now contain user-specific configuration.
sed -i '/"_comment": "#ddev-generated"/d' composer.local.json 2>/dev/null || true
sed -i '/#ddev-generated/d' composer.local.lock 2>/dev/null || true

echo ""
printf '\033[32m  Done! drupal/%s is ready for development in %s\033[0m\n' "$MODULE_NAME" "$MODULE_DIR"

# Show require-dev dependencies with suggestions for how to install them.
if [ -f "$MODULE_DIR/composer.json" ]; then
  DEV_DEPS=$(jq -r '."require-dev" // {} | to_entries[] | "\(.key) \(.value)"' "$MODULE_DIR/composer.json")
  if [ -n "$DEV_DEPS" ]; then
    printf '\n'
    printf '  \033[1mDev dependencies (not installed):\033[0m\n'
    while read -r pkg version; do
      if [[ "$pkg" == drupal/* ]]; then
        name="${pkg#drupal/}"
        printf '    %s:%s  ->  \033[36mddev add-module %s\033[0m\n' "$pkg" "$version" "$name"
      else
        printf '    %s:%s  ->  \033[36mddev composer require --dev %s\033[0m\n' "$pkg" "$version" "$pkg"
      fi
    done <<< "$DEV_DEPS"
  fi
fi
